# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Server JWT secret key (optional fallback exists in code)
JWT_SECRET=

# The URL of your local FastAPI backend server (default: https://localhost)
VITE_API_URL=https://localhost

# Web3 Reown Project ID (configured on reown.com)
VITE_REOWN_PROJECT_ID=a0249da7-2581-4b01-a90d-b31e08e025f4

# Base Sepolia RPC URL (e.g. from Alchemy, Infura, or public node)
VITE_BASE_TESTNET_RPC_URL=https://sepolia.base.org

# Google OAuth Client ID for client reference/authentication redirects
VITE_GOOGLE_CLIENT_ID=
